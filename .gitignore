.venv/
__pycache__/
*.pyc

# Local databases are development artifacts.
db.sqlite3
backend/db.sqlite3

# Local environment files must not be committed.
.env
.vscode/

# Real Aquarium files and temporary prototypes stay outside Git.
/data/
/docs/maquette_figma/
*.aux
*.fdb_latexmk
*.fls
*.log
*.out
*.synctex.gz
*.toc

# Frontend build artifacts and dependencies.
frontend/node_modules/
frontend/dist/

# Migration source files must remain versioned even when a developer has a
# global `*.py` ignore rule.
!backend/apps/*/migrations/*.py
