# Copy this file to backend/.env and fill in your real values.
# backend/.env is git-ignored and must never be committed.

# PostgreSQL connection. If POSTGRES_DB is set, Django uses PostgreSQL;
# otherwise it falls back to the local SQLite database.
POSTGRES_DB=POLYPBASE
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Neon/cloud requires SSL: set POSTGRES_SSLMODE=require. Local can stay "prefer".
POSTGRES_SSLMODE=prefer

# Django settings.
# DJANGO_DEBUG defaults to 0 (production-safe). Development must set it to 1,
# otherwise Django forces HTTPS and the local app becomes unreachable.
DJANGO_DEBUG=1

# Required as soon as DJANGO_DEBUG=0: Django refuses to start without it, on
# purpose (a key committed to the repo would let anyone forge sessions).
# Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=change_me_to_a_long_random_string

# Hosts and origins allowed to reach the app (comma-separated).
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Public base URL embedded in QR codes (no trailing slash). Each box QR code
# points to {PUBLIC_BASE_URL}/bac/<id>/. Use the production domain in prod,
# e.g. https://polypbase.aquarium-paris.fr
PUBLIC_BASE_URL=http://127.0.0.1:8000

# --- Production only (ignored while DJANGO_DEBUG=1) ---------------------------
# When DEBUG is off, HTTPS is forced and cookies are marked Secure automatically.
# These knobs only exist to adjust HSTS, which browsers cache and is therefore
# hard to undo. Raise the duration once HTTPS is proven stable.
# DJANGO_SECURE_SSL_REDIRECT=1
# DJANGO_SECURE_HSTS_SECONDS=86400
# Enable only if EVERY subdomain of the domain is served over HTTPS:
# DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=0
# Irreversible (hardcoded into browsers) - leave off unless you know why:
# DJANGO_SECURE_HSTS_PRELOAD=0
